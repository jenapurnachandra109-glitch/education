<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <h1 class="page-title">Branch Management</h1>
        <p class="page-sub">Manage academic departments</p>
    </div>
</div>

<div class="two-col-layout">
    <!-- Add Branch Form -->
    <div class="card" style="align-self:start">
        <div class="card-header"><h3 class="card-title">Add New Branch</h3></div>
        <form method="POST" action="/admin/branches" class="form-stacked">
            <div class="form-group">
                <label class="form-label">Branch Name</label>
                <input type="text" name="name" class="form-input" placeholder="e.g. Computer Science & Engineering" required>
            </div>
            <div class="form-group">
                <label class="form-label">Branch Code</label>
                <input type="text" name="code" class="form-input" placeholder="e.g. CSE" maxlength="10" required style="text-transform:uppercase">
            </div>
            <button type="submit" class="btn btn-primary">Add Branch</button>
        </form>
    </div>

    <!-- Existing Branches -->
    <div class="card">
        <div class="card-header"><h3 class="card-title">All Branches (<%= branches.length %>)</h3></div>
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr><th>Code</th><th>Name</th><th>Students</th><th>Action</th></tr>
                </thead>
                <tbody>
                <% branches.forEach(b => { %>
                    <tr>
                        <td><span class="badge badge-admin"><%= b.code %></span></td>
                        <td><strong><%= b.name %></strong></td>
                        <td><%= b.student_count %></td>
                        <td>
                            <% if (b.student_count === 0) { %>
                            <form method="POST" action="/admin/branches/<%= b.id %>/delete" onsubmit="return confirm('Delete branch?')">
                                <button class="btn btn-xs btn-danger">🗑</button>
                            </form>
                            <% } else { %>
                            <span class="text-muted text-sm">In use</span>
                            <% } %>
                        </td>
                    </tr>
                <% }) %>
                <% if (!branches.length) { %>
                    <tr><td colspan="4" class="text-center text-muted">No branches yet</td></tr>
                <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
