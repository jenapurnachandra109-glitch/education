<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= code %> – OUTrack</title>
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
</head>
<body class="auth-body">
<div class="auth-center">
    <div class="auth-card" style="text-align:center">
        <div style="font-size:5rem;margin-bottom:1rem"><%= code === 404 ? '🔍' : '⚠️' %></div>
        <h1 style="font-size:3rem;font-family:'DM Serif Display',serif;color:var(--text-primary)"><%= code %></h1>
        <p style="color:var(--text-muted);margin:0.5rem 0 2rem"><%= message %></p>
        <a href="/" class="btn btn-primary">← Go Home</a>
    </div>
</div>
</body>
</html>
