<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <h1 class="page-title">My Profile</h1>
        <p class="page-sub">Manage your account information</p>
    </div>
</div>

<div class="profile-layout">
    <!-- Left: Photo + Summary -->
    <div class="profile-sidebar">
        <div class="card profile-photo-card">
            <div class="profile-photo-wrap">
                <img src="/uploads/<%= user.profile_photo || 'default.png' %>"
                     class="profile-photo" id="photoPreview" alt="Profile">
                <div class="photo-overlay">📷 Change</div>
            </div>
            <h3 class="profile-name"><%= user.name %></h3>
            <span class="badge badge-<%= user.role %>" style="margin:0.5rem auto;display:table"><%= user.role %></span>
            <p class="profile-email"><%= user.email %></p>

            <!-- Photo upload form -->
            <form method="POST" action="/profile/photo" enctype="multipart/form-data" id="photoForm">
                <input type="file" name="photo" id="photoInput" accept="image/*" style="display:none"
                       onchange="document.getElementById('photoForm').submit()">
            </form>

            <% if (extra) { %>
            <div class="profile-meta">
                <% if (user.role === 'student') { %>
                    <div class="meta-row"><span>Roll No</span><strong><%= extra.roll_no %></strong></div>
                    <div class="meta-row"><span>Branch</span><strong><%= extra.branch_name %> (<%= extra.code %>)</strong></div>
                    <div class="meta-row"><span>Semester</span><strong><%= extra.semester %></strong></div>
                <% } else if (user.role === 'professor') { %>
                    <div class="meta-row"><span>Employee ID</span><strong><%= extra.employee_id %></strong></div>
                    <div class="meta-row"><span>Designation</span><strong><%= extra.designation %></strong></div>
                <% } %>
            </div>
            <% } %>

            <button class="btn btn-outline btn-full" onclick="document.getElementById('photoInput').click()" style="margin-top:1rem">
                📷 Change Photo
            </button>
        </div>
    </div>

    <!-- Right: Edit forms -->
    <div class="profile-main">
        <!-- Personal Info -->
        <div class="card" style="margin-bottom:1.5rem">
            <div class="card-header"><h3 class="card-title">Personal Information</h3></div>
            <form method="POST" action="/profile/update" class="form-stacked">
                <div class="form-grid-2">
                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="name" class="form-input" value="<%= user.name %>" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-input" value="<%= user.email %>" disabled>
                        <small class="form-hint">Email cannot be changed</small>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Phone Number</label>
                    <input type="tel" name="phone" class="form-input" value="<%= user.phone || '' %>" placeholder="+91 XXXXX XXXXX">
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">✓ Save Changes</button>
                </div>
            </form>
        </div>

        <!-- Change Password -->
        <div class="card">
            <div class="card-header"><h3 class="card-title">🔒 Change Password</h3></div>
            <form method="POST" action="/profile/change-password" class="form-stacked">
                <div class="form-group">
                    <label class="form-label">Current Password</label>
                    <input type="password" name="current" class="form-input" required placeholder="Your current password">
                </div>
                <div class="form-grid-2">
                    <div class="form-group">
                        <label class="form-label">New Password</label>
                        <input type="password" name="password" class="form-input" required placeholder="Min 8 characters" minlength="8">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirm New Password</label>
                        <input type="password" name="confirm" class="form-input" required placeholder="Repeat new password">
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">🔒 Update Password</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Preview photo before upload
document.getElementById('photoInput').addEventListener('change', function() {
    const file = this.files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = e => document.getElementById('photoPreview').src = e.target.result;
        reader.readAsDataURL(file);
    }
});
</script>

<%- include('../partials/footer') %>
