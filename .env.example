# EduTrack Environment Configuration
# Copy this to .env and fill in your values
SESSION_SECRET=18fde65480ccb980e05f5e37533ce70ff9e5417b2c83561b748cfc067a9e6521
secret: process.env.SESSION_SECRET
# Server
PORT=3000
BASE_URL=http://localhost:3000

# Session (use a long random string in production)
SESSION_SECRET=change-this-to-a-long-random-secret-string

# Email (SMTP) – use Ethereal for dev, real SMTP for production
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_ethereal_user@ethereal.email
SMTP_PASS=your_ethereal_password

# For Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youremail@gmail.com
# SMTP_PASS=your_app_password
